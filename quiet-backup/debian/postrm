#!/bin/sh
set -e

USER=quiet-backup
GROUP=quiet-backup
STATEDIR=/var/lib/quiet-backup

case "$1" in
    purge)
        if [ -d "$STATEDIR" ]; then
            rm -rf "$STATEDIR"
        fi

        if command -v deluser >/dev/null 2>&1; then
            if getent passwd "$USER" >/dev/null 2>&1; then
                deluser --quiet --system "$USER" >/dev/null 2>&1 || true
            fi

            if getent group "$GROUP" >/dev/null 2>&1; then
                deluser --quiet --system --group --only-if-empty "$GROUP" >/dev/null 2>&1 || true
            fi
        fi
        ;;
    remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        ;;
    *)
        echo "postrm called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0